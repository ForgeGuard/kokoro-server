# ForgeGuard Kokoro Server — example configuration.
#
# Copy to `.env` and adjust. Every value here is a default; uncomment only what
# you need to change. Settings are read by pydantic-settings (case-insensitive
# env vars, no prefix). See README.md for the full reference.

# ─────────────────────────────────────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────────────────────────────────────
# HOST=0.0.0.0
# PORT=8880
# API_LOG_LEVEL=INFO            # app logger: TRACE|DEBUG|INFO|WARNING|ERROR
# UVICORN_LOG_LEVEL=info        # uvicorn logger

# ─────────────────────────────────────────────────────────────────────────────
# Authentication
#   Optional bearer token. When UNSET the API is open (auth disabled). When set,
#   /v1, /dev and /debug require `Authorization: Bearer <API_KEY>`.
#   /health, /ready, /system and the /web console always stay open.
# ─────────────────────────────────────────────────────────────────────────────
# API_KEY=change-me

# ─────────────────────────────────────────────────────────────────────────────
# TLS / HTTPS (built-in, self-signed on first run — no reverse proxy needed)
#   With TLS_ENABLED=true the server speaks HTTPS directly. If no cert is
#   provided and TLS_SELF_SIGNED=true, a self-signed cert is generated on first
#   start and persisted under {OUTPUT_DIR}/tls, so restarts reuse it. Browsers
#   warn on self-signed certs — expected for local/self-hosted testing. Point
#   TLS_CERT_FILE / TLS_KEY_FILE at a real cert for anything public.
# ─────────────────────────────────────────────────────────────────────────────
# TLS_ENABLED=false
# TLS_SELF_SIGNED=true
# TLS_CN=localhost
# TLS_SAN=host.local,10.0.0.5   # extra SANs (comma-separated), optional
# TLS_CERT_FILE=                # default: {OUTPUT_DIR}/tls/cert.pem
# TLS_KEY_FILE=                 # default: {OUTPUT_DIR}/tls/key.pem

# ─────────────────────────────────────────────────────────────────────────────
# Model / device
# ─────────────────────────────────────────────────────────────────────────────
# USE_GPU=true                  # use CUDA/MPS if available; false forces CPU
# WARMUP_ON_START=true          # load+warm model at startup (else on 1st request)
# DEFAULT_VOICE=af_heart
# DEVICE_TYPE=                  # force cuda|mps|cpu (default: auto-detect)

# ─────────────────────────────────────────────────────────────────────────────
# Storage
#   OUTPUT_DIR holds generated audio and, when TLS is on, the self-signed cert.
#   In containers, mount a volume here and set OUTPUT_DIR=/data to persist both.
# ─────────────────────────────────────────────────────────────────────────────
# OUTPUT_DIR=output

# ─────────────────────────────────────────────────────────────────────────────
# Web console
# ─────────────────────────────────────────────────────────────────────────────
# ENABLE_WEB_PLAYER=true
# CORS_ENABLED=true
# CORS_ORIGINS=["*"]

# ─────────────────────────────────────────────────────────────────────────────
# Text chunking (advanced — usually leave default)
# ─────────────────────────────────────────────────────────────────────────────
# TARGET_MIN_TOKENS=175
# TARGET_MAX_TOKENS=250
# ABSOLUTE_MAX_TOKENS=450

# ─────────────────────────────────────────────────────────────────────────────
# Model download (build/first-run; weights are baked into published images)
# ─────────────────────────────────────────────────────────────────────────────
# DOWNLOAD_MODEL=false
# MODEL_DOWNLOAD_BASE_URL=https://huggingface.co/hexgrad/Kokoro-82M/resolve/main
# MODEL_SHA256=                 # required if using a custom MODEL_DOWNLOAD_BASE_URL
