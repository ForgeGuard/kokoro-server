{
  "name": "kokoro-server",
  "build": {
    "dockerfile": "Dockerfile"
  },
  // Docker-outside-of-docker: the host's daemon builds/runs the server
  // images and compose stacks (this also gives GPU access on Jetson/CUDA
  // hosts via the host runtime — the devcontainer itself stays CPU-only).
  "features": {
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {}
  },
  "postCreateCommand": "uv sync --extra test --extra cpu",
  "forwardPorts": [8880],
  "portsAttributes": {
    "8880": { "label": "kokoro-server" }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "charliermarsh.ruff",
        "github.vscode-github-actions",
        "ms-azuretools.vscode-docker",
        "dbaeumer.vscode-eslint"
      ],
      "settings": {
        "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python"
      }
    }
  },
  "remoteUser": "vscode"
}
